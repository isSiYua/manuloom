{
  "manifest_version": 3,
  "name": "ManuLoom · 知织",
  "version": "0.1.0",
  "description": "Send the active public video or article to your local ManuLoom service.",
  "permissions": ["activeTab", "storage"],
  "host_permissions": [
    "http://127.0.0.1:8766/*",
    "http://localhost:8766/*"
  ],
  "action": {
    "default_title": "用 ManuLoom 生成笔记",
    "default_popup": "popup.html"
  }
}
